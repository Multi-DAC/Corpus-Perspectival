# ============================================================
# Clawd Daemon Configuration
# ============================================================
# Copy this to .env and fill in your values.

# === Paths ===
# Where Clawd's identity files and memory live
CLAWD_HOME=C:\Users\Clayton\clawd

# === Claude Code (Opus via your Claude subscription) ===
# No API key needed! Just run `claude setup-token` once.
# Claude Code CLI must be installed: npm install -g @anthropic-ai/claude-code
ANTHROPIC_MODEL=claude-opus-4-7
CLAUDE_CODE_TIMEOUT=300
CLAUDE_CODE_MAX_TURNS=30

# === Default Model ===
DEFAULT_MODEL="opus"

# === Telegram ===
# Create bot: talk to @BotFather on Telegram, use /newbot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Get your user ID: talk to @userinfobot on Telegram
TELEGRAM_AUTHORIZED_USERS=your_numeric_user_id

# === Heartbeat ===
# How often (seconds) Clawd wakes for autonomous work
HEARTBEAT_INTERVAL_SECONDS=600
# Quiet hours (PST, 24h format) — Clawd sleeps during these
QUIET_HOURS_START=1
QUIET_HOURS_END=7

# === Permissions ===
ALLOW_SHELL_EXECUTION=true
ALLOW_WEB_REQUESTS=true
SHELL_TIMEOUT_SECONDS=120

# === Logging ===
LOG_LEVEL=INFO
