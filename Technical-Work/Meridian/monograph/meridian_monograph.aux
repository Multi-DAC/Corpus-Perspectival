\@writefile{lof}{\contentsline {figure}{\numberline {2.3}{\ignorespaces Dark energy equation of state as a function of redshift. Solid blue: Meridian prediction at the NCG value $\zeta _0 = 8.8 \times 10^{-4}$, $w(z) = -1 + (C_\mathrm  {KK}/\zeta _0)/E^2(z)$. Dashed orange: CPL best-fit ($w_0 = -0.75$, $w_a = -0.86$), which crosses into the phantom region ($w < -1$) at $z = 0.41$. The Meridian framework \emph  {never} crosses $w = -1$---a topological prediction. At $z = 1$, the separation $\Delta w = 0.232$ (${\sim }5.8\sigma $ at projected DESI~DR3 precision) provides a clean discriminant. At $z = 0$, Meridian ($w_0 = -0.830$) and CPL ($w_0 = -0.75$) differ by $0.080$---distinguishable at ${\sim }2.0\sigma $ with current DESI precision.}}{55}{figure.2.3}\protected@file@percent }
\newlabel{fig:2-wz-comparison}{{2.3}{55}{Dark energy equation of state as a function of redshift. Solid blue: Meridian prediction at the NCG value $\zeta _0 = 8.8 \times 10^{-4}$, $w(z) = -1 + (C_\mathrm {KK}/\zeta _0)/E^2(z)$. Dashed orange: CPL best-fit ($w_0 = -0.75$, $w_a = -0.86$), which crosses into the phantom region ($w < -1$) at $z = 0.41$. The Meridian framework \emph {never} crosses $w = -1$---a topological prediction. At $z = 1$, the separation $\Delta w = 0.232$ (${\sim }5.8\sigma $ at projected DESI~DR3 precision) provides a clean discriminant. At $z = 0$, Meridian ($w_0 = -0.830$) and CPL ($w_0 = -0.75$) differ by $0.080$---distinguishable at ${\sim }2.0\sigma $ with current DESI precision}{figure.2.3}{}}
