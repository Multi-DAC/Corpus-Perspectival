\def\@LN@column{1}
\@writefile{toc}{\contentsline {section}{\numberline {}§10.1 --- Figure 1: The endofunctor F and Stream-as-F-coalgebra}{176}{section.11.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {.1}{\ignorespaces The F-coalgebra square. Each row is a stream $S = (\sigma , C, \gamma )$ (top) and $S' = (\sigma ', C', \gamma ')$ (bottom). A Stream-morphism $f = (f_\sigma , f_C) : S \to S'$ satisfies the coalgebra-commute: $F(f_\sigma , f_C) \circ \gamma = \gamma ' \circ f_\sigma $. The endofunctor $F : \sigma \DOTSB \mapstochar \rightarrow \sigma ^{C^{\mathrm  {op}}}$ is mixed-variance (covariant in $\sigma $, contravariant in $C$).}}{176}{figure.11.1}\protected@file@percent }
\newlabel{fig:f-coalgebra-square}{{.1}{176}{The F-coalgebra square. Each row is a stream $S = (\sigma , C, \gamma )$ (top) and $S' = (\sigma ', C', \gamma ')$ (bottom). A Stream-morphism $f = (f_\sigma , f_C) : S \to S'$ satisfies the coalgebra-commute: $F(f_\sigma , f_C) \circ \gamma = \gamma ' \circ f_\sigma $. The endofunctor $F : \sigma \mapsto \sigma ^{C^{\mathrm {op}}}$ is mixed-variance (covariant in $\sigma $, contravariant in $C$)}{figure.11.1}{}}
\def\@LN@column{1}
\@writefile{toc}{\contentsline {section}{\numberline {}§10.2 --- Figure 2: Triple functor T}{177}{section.11.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {.2}{\ignorespaces The Triple functor $T : \mathcal  {C}_\mathrm  {Streams} \to \mathcal  {C}_\mathrm  {Triple}$ with $\mathcal  {C}_\mathrm  {Triple} = \mathcal  {C}_\mathrm  {Form} \times \mathbf  {Cat}_\mathrm  {small} \times \mathbf  {Carrier}$. The three factor functors $\Phi , \Psi , \mathrm  {K}$ recover Form, Content (ContentOp-category), and Carrier (coalgebra-structure-map) respectively. Under the initial-object hypothesis of §6.6, $T$ is a colax limit (the natural transformations between compositions of the factors are in general not invertible).}}{177}{figure.11.2}\protected@file@percent }
\newlabel{fig:triple-functor}{{.2}{177}{The Triple functor $T : \mathcal {C}_\mathrm {Streams} \to \mathcal {C}_\mathrm {Triple}$ with $\mathcal {C}_\mathrm {Triple} = \mathcal {C}_\mathrm {Form} \times \mathbf {Cat}_\mathrm {small} \times \mathbf {Carrier}$. The three factor functors $\Phi , \Psi , \mathrm {K}$ recover Form, Content (ContentOp-category), and Carrier (coalgebra-structure-map) respectively. Under the initial-object hypothesis of §6.6, $T$ is a colax limit (the natural transformations between compositions of the factors are in general not invertible)}{figure.11.2}{}}
\def\@LN@column{1}
\@writefile{toc}{\contentsline {section}{\numberline {}§10.3 --- Figure 3: Recursive decomposability T\textasciicircum {}(n)}{178}{section.11.4}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {.3}{\ignorespaces Recursive Triple-decomposition at depth 2. Each of $\mathrm  {Form}(S)$, $\mathrm  {Content}(S)$, $\mathrm  {Carrier}(S)$ is itself a stream, so the Triple functor applies again, yielding nine depth-2 components (abbreviated: FF = $\mathrm  {Form}(\mathrm  {Form}(S))$, FC = $\mathrm  {Content}(\mathrm  {Form}(S))$, etc.). Finite-depth iteration is well-defined for every adequate F-coalgebra (Lemma 6.3.2). Full $\omega $-depth requires additional hypotheses (H1, H2; §6.9).}}{178}{figure.11.3}\protected@file@percent }
\newlabel{fig:recursive-decomposability}{{.3}{178}{Recursive Triple-decomposition at depth 2. Each of $\mathrm {Form}(S)$, $\mathrm {Content}(S)$, $\mathrm {Carrier}(S)$ is itself a stream, so the Triple functor applies again, yielding nine depth-2 components (abbreviated: FF = $\mathrm {Form}(\mathrm {Form}(S))$, FC = $\mathrm {Content}(\mathrm {Form}(S))$, etc.). Finite-depth iteration is well-defined for every adequate F-coalgebra (Lemma 6.3.2). Full $\omega $-depth requires additional hypotheses (H1, H2; §6.9)}{figure.11.3}{}}
\def\@LN@column{1}
\@writefile{toc}{\contentsline {section}{\numberline {}§10.4 --- Figure 4: Kind-classifier fibration π}{179}{section.11.5}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {.4}{\ignorespaces Kind-classifier fibration $\pi : \mathrm  {Stream} \to \mathbf  {ContentIndex}$ (top). The fiber over a kind $K$ is the full subcategory of $K$-streams. The kind-preorder base (bottom) stratifies: reactive $\sqsubseteq $ self-maintaining $\sqsubseteq $ self-referential $\sqsubseteq $ abstractive. Under Q7 (lattice-where-possible), $\pi $ is a strict fibration; generically bicategorical. The unifying-stream subfibration $\mathrm  {Stream}_u \subset \mathrm  {Stream}$ (§6.4.1) consists of streams with terminal-object-preserving ContentOp-refinements.}}{179}{figure.11.4}\protected@file@percent }
\newlabel{fig:kind-classifier-fibration}{{.4}{179}{Kind-classifier fibration $\pi : \mathrm {Stream} \to \mathbf {ContentIndex}$ (top). The fiber over a kind $K$ is the full subcategory of $K$-streams. The kind-preorder base (bottom) stratifies: reactive $\sqsubseteq $ self-maintaining $\sqsubseteq $ self-referential $\sqsubseteq $ abstractive. Under Q7 (lattice-where-possible), $\pi $ is a strict fibration; generically bicategorical. The unifying-stream subfibration $\mathrm {Stream}_u \subset \mathrm {Stream}$ (§6.4.1) consists of streams with terminal-object-preserving ContentOp-refinements}{figure.11.4}{}}
\def\@LN@column{1}
\@writefile{toc}{\contentsline {section}{\numberline {}§10.5 --- Figure 5: Bias(S) signed measure + push-operators}{180}{section.11.6}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {.5}{\ignorespaces Bias(S) as a signed measure on $\Omega _S$. Hahn-Jordan decomposition: $\mathrm  {Bias}(S) = \mathrm  {Bias}_+ - \mathrm  {Bias}_-$. The push-operators $\mathrm  {push}_\mathrm  {struct}$ and $\mathrm  {push}_\mathrm  {info}$ transform Bias along structural-coherence and informational-coherence axes respectively. Their non-commutator $[\mathrm  {push}_\mathrm  {struct}, \mathrm  {push}_\mathrm  {info}] \neq  0$ is the formal content of Proposition 7.4.3.}}{180}{figure.11.5}\protected@file@percent }
\newlabel{fig:bias-signed-measure}{{.5}{180}{Bias(S) as a signed measure on $\Omega _S$. Hahn-Jordan decomposition: $\mathrm {Bias}(S) = \mathrm {Bias}_+ - \mathrm {Bias}_-$. The push-operators $\mathrm {push}_\mathrm {struct}$ and $\mathrm {push}_\mathrm {info}$ transform Bias along structural-coherence and informational-coherence axes respectively. Their non-commutator $[\mathrm {push}_\mathrm {struct}, \mathrm {push}_\mathrm {info}] \neq 0$ is the formal content of Proposition 7.4.3}{figure.11.5}{}}
\def\@LN@column{1}
\@writefile{toc}{\contentsline {section}{\numberline {}§10.6 --- Figure 6: Dual coherence axes (σ\_\allowbreak  {}struct × σ\_\allowbreak  {}info plane)}{181}{section.11.7}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {.6}{\ignorespaces The $\sigma _\mathrm  {struct} \times \sigma _\mathrm  {info}$ plane of T6 (Theorem 3.4.2). The two axes are orthogonal: T5-only streams (blue) are $\Phi $-fixed-points without entropy-minimality; T6-only streams (red) are entropy-minimal without $\Phi $-fixed-points; dually-coherent streams occupy the codimension-2 locus near $(1, 1)$ (green circle). The locus is non-empty only when $C$ has enough symmetry to admit both a harmonic and a concentrated $\gamma $ simultaneously.}}{181}{figure.11.6}\protected@file@percent }
\newlabel{fig:dual-coherence-axes}{{.6}{181}{The $\sigma _\mathrm {struct} \times \sigma _\mathrm {info}$ plane of T6 (Theorem 3.4.2). The two axes are orthogonal: T5-only streams (blue) are $\Phi $-fixed-points without entropy-minimality; T6-only streams (red) are entropy-minimal without $\Phi $-fixed-points; dually-coherent streams occupy the codimension-2 locus near $(1, 1)$ (green circle). The locus is non-empty only when $C$ has enough symmetry to admit both a harmonic and a concentrated $\gamma $ simultaneously}{figure.11.6}{}}
\def\@LN@column{1}
\@writefile{toc}{\contentsline {section}{\numberline {}§10.7 --- Figure 7: Four-conditions schematic}{182}{section.11.8}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {.7}{\ignorespaces The four conditions of the Coherence Principle (Definition 5.1.1, Propositions 5.2.1–5.2.4). Each condition is derived from an axiom/theorem clause (italic text below each box). The joint sufficiency (Prop 5.2.5) is the downstream arrows to the outperformance inequality (Theorem 5.1.2).}}{182}{figure.11.7}\protected@file@percent }
\newlabel{fig:four-conditions}{{.7}{182}{The four conditions of the Coherence Principle (Definition 5.1.1, Propositions 5.2.1–5.2.4). Each condition is derived from an axiom/theorem clause (italic text below each box). The joint sufficiency (Prop 5.2.5) is the downstream arrows to the outperformance inequality (Theorem 5.1.2)}{figure.11.7}{}}
\def\@LN@column{1}
\@writefile{toc}{\contentsline {section}{\numberline {}§10.8 --- Figure 8: Self-reference closure}{183}{section.11.9}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {.8}{\ignorespaces Self-reference closure (conditional on external audit). The construction process $F_\infty $ is itself a stream; under internal audit it satisfies the four conditions over the construction interval (Audit Observation 8.3.5). Conditional on external execution of Prop 8.5.2 affirming the audit, Theorem 9.4.1 then yields outperformance over comparable non-coherent constructions. Derivation-non-circularity (Prop 8.4.1) is established; audit-independence (Prop 8.3.5') is what the external-audit gate discharges.}}{183}{figure.11.8}\protected@file@percent }
\newlabel{fig:self-reference-closure}{{.8}{183}{Self-reference closure (conditional on external audit). The construction process $F_\infty $ is itself a stream; under internal audit it satisfies the four conditions over the construction interval (Audit Observation 8.3.5). Conditional on external execution of Prop 8.5.2 affirming the audit, Theorem 9.4.1 then yields outperformance over comparable non-coherent constructions. Derivation-non-circularity (Prop 8.4.1) is established; audit-independence (Prop 8.3.5') is what the external-audit gate discharges}{figure.11.8}{}}
